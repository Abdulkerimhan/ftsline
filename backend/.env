# ===============================
# SERVER
# ===============================
PORT=5000
NODE_ENV=development

# ===============================
# DATABASE (MongoDB)
# ===============================
MONGO_URI=mongodb://127.0.0.1:27017/ftsline

# ===============================
# AUTH / SECURITY (JWT)
# ===============================

# ❌ ESKİ (KULLANILMIYOR)
# JWT_SECRET=ftsline_super_secret_key_123456
# JWT_EXPIRES_IN=7d

# ✅ YENİ (ACCESS + REFRESH)
ACCESS_TOKEN_SECRET=ftsline_access_secret_123456
REFRESH_TOKEN_SECRET=ftsline_refresh_secret_789456

# Token süreleri
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=30d

# ===============================
# MATRIX / SYSTEM
# ===============================
MATRIX_ID=MAIN
PENDING_DAYS=7
MATRIX_REMOVE_AFTER_MONTHS=2

# ===============================
# PAYMENT (USDT - TRC20)
# ===============================
USDT_NETWORK=TRC20
USDT_CURRENCY=USDT

# Şirketin TRC20 cüzdan adresi
COMPANY_USDT_ADDRESS=TRxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Minimum çekim tutarı
MIN_WITHDRAW_AMOUNT=100

# Ödeme günü (ayın kaçı)
PAYOUT_DAY=15

# ===============================
# UNILEVEL (SIGNUP)
# ===============================
# Unilevel sadece İLK SIGNUP ödemesinde çalışır.
# Hesaplama tabanı sabittir (ödediği tutar ne olursa olsun)
UNILEVEL_BASE_AMOUNT=74.99

# Kariyer/aktiflik şartları
UNILEVEL_REQUIRE_ACTIVE=true
UNILEVEL_REQUIRE_NO_MISSED_2MONTHS=true

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=debug

# ===============================
# OPTIONAL (ileride)
# ===============================
# REDIS_URL=redis://127.0.0.1:6379
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
